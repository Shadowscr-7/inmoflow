{
  "name": "inmoflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo lint",
    "db:generate": "pnpm --filter @inmoflow/db generate",
    "db:migrate": "pnpm --filter @inmoflow/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @inmoflow/db migrate:deploy",
    "db:push": "pnpm --filter @inmoflow/db db:push",
    "db:seed": "pnpm --filter @inmoflow/db seed",
    "db:studio": "pnpm --filter @inmoflow/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.17.1"
}
