FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.17.1 --activate
WORKDIR /app

# ─── Install + Build ──────────────────────────────────
FROM base AS builder
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @inmoflow/shared build
ENV NEXT_TELEMETRY_DISABLED=1
# In production, NEXT_PUBLIC_API_URL="" means same-origin (nginx proxies /api → api:4000)
# In dev, it defaults to http://localhost:4000
ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
RUN pnpm --filter @inmoflow/web build

# ─── Production ────────────────────────────────────────
FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs
EXPOSE 3000
ENV PORT=3000
# Docker overrides HOSTNAME with container ID — force 0.0.0.0 so Next.js binds correctly
CMD ["sh", "-c", "HOSTNAME=0.0.0.0 node apps/web/server.js"]
