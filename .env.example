# ═══════════════════════════════════════════════════════════════
# InmoFlow — Variables de Entorno
# ═══════════════════════════════════════════════════════════════
#
# 🔴 CRÍTICAS: La app no arranca sin estas
# 🟡 IMPORTANTES: Funcionalidad limitada sin estas
# 🟢 OPCIONALES: Features extra
#
# Para producción copiar a .env.prod y editar
# ═══════════════════════════════════════════════════════════════

# ─── 🔴 [CRÍTICA] Database ───────────────────────────────
# Connection string de PostgreSQL. CAMBIAR password en producción.
DATABASE_URL=postgresql://inmoflow:inmoflow@localhost:5432/inmoflow?schema=public

# ─── 🔴 [CRÍTICA] Redis ──────────────────────────────────
# Usado para colas BullMQ (worker) y rate limiting.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=inmoflow-redis

# ─── 🔴 [CRÍTICA] Autenticación JWT ──────────────────────
# Secreto para firmar tokens. En producción usar: openssl rand -base64 48
JWT_SECRET=change-me-in-production-super-secret-key
# Expiración del access token (corto = más seguro)
JWT_EXPIRES_IN=15m
# Expiración del refresh token
JWT_REFRESH_EXPIRES_IN=7d

# ─── 🔴 [CRÍTICA en prod] Dominio ────────────────────────
# Solo para producción. Usado por nginx y CORS.
DOMAIN=tudominio.com

# ─── 🔴 [CRÍTICA en prod] Database Passwords ─────────────
# Solo para docker-compose.prod.yml
# POSTGRES_USER=inmoflow
# POSTGRES_PASSWORD=una-password-segura-aqui
# POSTGRES_DB=inmoflow

# ─── 🟡 [IMPORTANTE] API ─────────────────────────────────
API_PORT=4000
NODE_ENV=development
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

# ─── 🟡 [IMPORTANTE] Frontend ────────────────────────────
# URL del API vista desde el NAVEGADOR del usuario.
# En desarrollo: http://localhost:4000
# En producción: dejar VACÍO (nginx proxiea /api al backend)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── 🟡 [IMPORTANTE] WhatsApp via Evolution API ──────────
# URL de tu instancia de Evolution API
EVOLUTION_API_URL=http://localhost:8080
# API Key de Evolution
EVOLUTION_API_KEY=change-me
# Secret para validar webhooks entrantes (opcional)
EVOLUTION_WEBHOOK_SECRET=

# ─── 🟢 [OPCIONAL] Telegram ──────────────────────────────
# Token del bot de Telegram (obtener de @BotFather)
TELEGRAM_BOT_TOKEN=

# ─── 🟢 [OPCIONAL] Meta / Facebook Lead Ads ──────────────
# App ID y Secret de tu Facebook App (developers.facebook.com)
META_APP_ID=
META_APP_SECRET=
# Token de verificación para webhooks de Meta
META_VERIFY_TOKEN=inmoflow-meta-verify
# Page Access Token (se obtiene via OAuth en la app)
META_PAGE_ACCESS_TOKEN=

# ─── 🟢 [OPCIONAL] MercadoLibre ──────────────────────────
# App ID y Secret de tu app en developers.mercadolibre.com
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
# Redirect URI (debe coincidir con la configurada en MeLi Developers)
MELI_REDIRECT_URI=https://tudominio.com/dashboard/mercadolibre

# ─── 🟢 [OPCIONAL] Plataforma ────────────────────────────
# Dominio base para URLs públicas
PLATFORM_DOMAIN=tuplataforma.com

# ─── 🟢 [OPCIONAL] SSL (solo para deploy.sh) ─────────────
# Email para Let's Encrypt
# SSL_EMAIL=tu@email.com

# ─── 🟢 [OPCIONAL] Alertas ───────────────────────────────
# Webhook URL para alertas del health check (Slack, Discord, etc.)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

