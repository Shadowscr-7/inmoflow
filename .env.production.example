# ═══════════════════════════════════════════════════════════════
# InmoFlow — Variables de Entorno (Producción)
# ═══════════════════════════════════════════════════════════════
# Copiar a .env.production y completar TODOS los valores marcados con ←
# ═══════════════════════════════════════════════════════════════

# ─── Dominio ──────────────────────────────────────────────
DOMAIN=crm.contacthouse.com.uy
PLATFORM_DOMAIN=contacthouse.com.uy

# ─── Base de datos ────────────────────────────────────────
DB_USER=inmoflow
DB_PASSWORD=                # ← Generar: openssl rand -base64 32
DB_NAME=inmoflow

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=             # ← Generar: openssl rand -base64 32

# ─── Autenticación ───────────────────────────────────────
JWT_SECRET=                 # ← Generar: openssl rand -base64 64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Evolution API (WhatsApp) ────────────────────────────
EVOLUTION_API_URL=https://wa.contacthouse.com.uy
EVOLUTION_API_KEY=ch_EVO2_api_key_8f91a5c6d4e74f0d9b8a3f1c2e7b5a9f
EVOLUTION_WEBHOOK_SECRET=   # ← Generar: openssl rand -hex 32

# ─── Meta / Facebook ─────────────────────────────────────
META_APP_ID=3528074904024379
META_APP_SECRET=da4d1a19f1b6648b3dfc42fe5ab48fe1
META_VERIFY_TOKEN=inm0flow_m3ta_v3r1fy_8kQ2xP9w
META_PAGE_ACCESS_TOKEN=

# ─── MercadoLibre ─────────────────────────────────────────
MELI_CLIENT_ID=1832966382280418
MELI_CLIENT_SECRET=XV2Z3T4k2BefED103OIpYYnbzV2Ysuvv
MELI_REDIRECT_URI=https://crm.contacthouse.com.uy/api/meli/callback

# ─── Telegram (opcional) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Traefik (ajustar según tu servidor) ─────────────────
# Ejecutar: docker network ls  para ver el nombre exacto
TRAEFIK_NETWORK=root_proxy
# Nombres de entrypoints de Traefik
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_ENTRYPOINT_HTTP=web
# Nombre del certresolver de Traefik para Let's Encrypt
TRAEFIK_CERTRESOLVER=mytlschallenge
